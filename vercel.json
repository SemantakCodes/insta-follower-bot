{
  "buildCommand": "pip install -r requirements.txt",
  "functions": {
    "api/bot.py": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/bot",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/bot",
      "schedule": "0 15 * * *"
    }
  ]
}

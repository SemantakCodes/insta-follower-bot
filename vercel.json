{
  "buildCommand": "pip install -r requirements.txt",
  "env": {
    "INSTAGRAM_USERNAME": "@INSTAGRAM_USERNAME",
    "INSTAGRAM_PASSWORD": "@INSTAGRAM_PASSWORD"
  },
  "envParallel": false,
  "functions": {
    "api/bot.py": {
      "memory": 3008,
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/bot",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/bot",
      "schedule": "0 15 * * *"
    }
  ]
}
